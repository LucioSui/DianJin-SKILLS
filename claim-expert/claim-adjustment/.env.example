# insurance-claim-adjustment 环境变量配置
# 复制为 .env 后填入实际值

# MCP服务器连接配置
CALCULATION_ENGINE_MCP_ENDPOINT=http://localhost:8080/mcp/calculation-engine
CLAIMS_SYSTEM_MCP_ENDPOINT=http://localhost:8080/mcp/claims-system
POLICY_SYSTEM_MCP_ENDPOINT=http://localhost:8080/mcp/policy-system

# 理算引擎超时设置（秒）
CALCULATION_TIMEOUT=30

# 核减金额告警阈值（占总费用比例）
DEDUCTION_ALERT_THRESHOLD=0.30

# 日志配置
AUDIT_LOG_PATH=./audit
LOG_LEVEL=INFO
